{
  "manifest_version": 3,
  "name": "PCC Clipboard Guard",
  "version": "1.0.0",
  "description": "Blocks clipboard operations on PointClickCare.com for data security and badge scan compliance.",
  "update_url": "https://bpapp360-rgb.github.io/pcc-clipboard-guard/update.xml",
  "key": "",
  "content_scripts": [
    {
      "matches": ["*://*.pointclickcare.com/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
